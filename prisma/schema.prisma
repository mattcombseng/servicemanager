generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STAFF
  CUSTOMER
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String?         @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role            @default(CUSTOMER)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  customer      Customer?
  appointments  Appointment[]   @relation("StaffCreatedAppointments")
  invoices      Invoice[]       @relation("StaffCreatedInvoices")
  accounts      Account[]
  sessions      Session[]
}

model Customer {
  id           String        @id @default(cuid())
  userId       String?       @unique
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  name         String
  email        String?
  phone        String?
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
  invoices     Invoice[]
}

model Service {
  id              String            @id @default(cuid())
  name            String
  description     String?
  defaultRate     Decimal           @db.Decimal(10, 2)
  durationMinutes Int
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  appointments    Appointment[]
  invoiceItems    InvoiceLineItem[]
  invoices        Invoice[]
}

model Appointment {
  id               String            @id @default(cuid())
  customerId       String
  serviceId        String
  startsAt         DateTime
  notes            String?
  status           AppointmentStatus @default(SCHEDULED)
  createdByStaffId String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  customer         Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  service          Service           @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  createdByStaff   User?             @relation("StaffCreatedAppointments", fields: [createdByStaffId], references: [id], onDelete: SetNull)

  @@index([customerId, startsAt])
}

model Invoice {
  id               String            @id @default(cuid())
  customerId       String
  serviceId        String
  issuedAt         DateTime
  dueAt            DateTime
  subtotal         Decimal           @db.Decimal(10, 2)
  taxAmount        Decimal           @db.Decimal(10, 2)
  total            Decimal           @db.Decimal(10, 2)
  status           InvoiceStatus     @default(DRAFT)
  notes            String?
  createdByStaffId String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  customer         Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  service          Service           @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  createdByStaff   User?             @relation("StaffCreatedInvoices", fields: [createdByStaffId], references: [id], onDelete: SetNull)
  lineItems        InvoiceLineItem[]
}

model InvoiceLineItem {
  id          String   @id @default(cuid())
  invoiceId   String
  description String
  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2)
  serviceId   String?
  createdAt   DateTime @default(now())
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  service     Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
